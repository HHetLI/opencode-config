{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "hephaestus": {
      "model": "ark-coding-plan/doubao-seed-2.0-code"
    },
    "oracle": {
      "model": "bailian-coding-plan/qwen3.5-plus"
    },
    "librarian": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.5-highspeed"
    },
    "explore": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.5-highspeed"
    },
    "multimodal-looker": {
      "model": "ark-coding-plan/kimi-k2.5"
    },
    "prometheus": {
      "model": "ark-coding-plan/kimi-k2.5"
    },
    "metis": {
      "model": "ark-coding-plan/kimi-k2.5"
    },
    "momus": {
      "model": "bailian-coding-plan/qwen3.5-plus"
    },
    "atlas": {
      "model": "bailian-coding-plan/kimi-k2.5"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "bailian-coding-plan/glm-5"
    },
    "ultrabrain": {
      "model": "ark-coding-plan/doubao-seed-2.0-code"
    },
    "deep": {
      "model": "ark-coding-plan/doubao-seed-2.0-code"
    },
    "artistry": {
      "model": "bailian-coding-plan/kimi-k2.5"
    },
    "quick": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.5-highspeed"
    },
    "unspecified-low": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.5-highspeed"
    },
    "unspecified-high": {
      "model": "bailian-coding-plan/qwen3.5-plus"
    },
    "writing": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.5-highspeed"
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 120000,
    "providerConcurrency": { "bailian-coding-plan": 5, "ark-coding-plan": 5 },
    "modelConcurrency": { "bailian-coding-plan/qwen3.5-plus": 3 }
  },
  "ralph_loop": { "enabled": true, "default_max_iterations": 20 }
}
