{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",

  // ==========================================
  // AGENTS 配置 - 针对可用模型优化
  // ==========================================
  "agents": {
    // Sisyphus: 主协调器 - Kimi K2.5最佳(Claude-like + Agent Swarm)
    // 备选: GLM 5 (同为Claude-family, 表现类似)
    "sisyphus": {
      "model": "ark-coding-plan/kimi-k2.5",
      "fallback_models": ["bailian-coding-plan/glm-5", "bailian-coding-plan/qwen3.5-plus"],
      "reasoningEffort": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      }
    },
    // Hephaestus: 深度工作者 - 无GPT-5.3 Codex时最佳替代
    // 可以尝试 doubao-seed-2.0-code 和 glm 5
    "hephaestus": {
      "model": "ark-coding-plan/doubao-seed-2.0-code",
      "fallback_models": ["bailian-coding-plan/glm-5"],
      "reasoningEffort": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      }
    },
    // Prometheus: 战略规划 - 需要Claude-like的指令遵循
    "prometheus": {
      "model": "bailian-coding-plan/glm-5",
      "fallback_models": ["ark-coding-plan/kimi-k2.5", "bailian-coding-plan/qwen3.5-plus"],
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel.",
      "reasoningEffort": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      }
    },
    // Metis: 计划顾问 - 同Prometheus
    "metis": {
      "model": "ark-coding-plan/kimi-k2.5",
      "fallback_models": ["bailian-coding-plan/glm-5", "bailian-coding-plan/qwen3.5-plus"],
      "reasoningEffort": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      }
    },
    // Atlas: Todo执行者 - Kimi K2.5是最佳选择(文档明确推荐)
    "atlas": {
      "model": "ark-coding-plan/kimi-k2.5",
      "fallback_models": ["bailian-coding-plan/kimi-k2.5", "bailian-coding-plan/glm-5", "bailian-coding-plan/qwen3.5-plus"],
      "reasoningEffort": "high"
    },
    // Oracle: 架构咨询 read-only
    "oracle": {
      "model": "bailian-coding-plan/glm-5",
      "fallback_models": ["bailian-coding-plan/qwen3.5-plus", "ark-coding-plan/doubao-seed-2.0-code"],
      "reasoningEffort": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      }
    },
    // Momus: 计划审查 - 需要高IQ但read-only
    "momus": {
      "model": "bailian-coding-plan/qwen3.5-plus",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-code"],
      "reasoningEffort": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      }
    },
    // Librarian: 文档搜索
    "librarian": {
      "model": "bailian-coding-plan/qwen3.5-plus",
      "fallback_models": ["minimax-cn-coding-plan/MiniMax-M2.5-highspeed"]
    },
    // Explore: 快速grep
    "explore": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.5-highspeed",
      "fallback_models": ["bailian-coding-plan/qwen3.5-plus"]
    },
    // Multimodal-Looker: 视觉分析
    "multimodal-looker": {
      "model": "bailian-coding-plan/qwen3.5-plus",
      "fallback_models": ["ark-coding-plan/kimi-k2.5"]
    }
  },
  // ==========================================
  // CATEGORIES 配置
  // ==========================================
  "categories": {
    // visual-engineering: UI/前端
    "visual-engineering": {
      "model": "ark-coding-plan/doubao-seed-2.0-code",
      "fallback_models": ["bailian-coding-plan/qwen3.5-plus", "bailian-coding-plan/kimi-k2.5"],
      "temperature": 0.7,
      "description": "Frontend, UI/UX, design, styling, animation"
    },
    // ultrabrain: 极限推理
    "ultrabrain": {
      "model": "bailian-coding-plan/glm-5",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-code"],
      "reasoningEffort": "high",
      "description": "Deep logical reasoning, complex architecture decisions"
    },
    // deep: 深度编码
    "deep": {
      "model": "ark-coding-plan/doubao-seed-2.0-code",
      "fallback_models": ["bailian-coding-plan/glm-5"],
      "reasoningEffort": "medium",
      "description": "Goal-oriented autonomous problem-solving, thorough research"
    },
    // artistry: 创意任务
    "artistry": {
      "model": "bailian-coding-plan/qwen3.5-plus",
      "fallback_models": ["ark-coding-plan/kimi-k2.5"],
      "temperature": 0.9,
      "description": "Highly creative/artistic tasks, novel ideas"
    },
    // quick: 快速任务
    "quick": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.5-highspeed",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-lite", "bailian-coding-plan/qwen3.5-plus"],
      "temperature": 0.3,
      "description": "Trivial tasks - single file changes, typo fixes, simple modifications"
    },
    // unspecified-low: 一般低强度
    "unspecified-low": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.5-highspeed",
      "fallback_models": ["bailian-coding-plan/qwen3.5-plus", "ark-coding-plan/doubao-seed-2.0-pro"],
      "description": "Tasks that don't fit other categories, low effort required"
    },
    // unspecified-high: 一般高强度
    "unspecified-high": {
      "model": "ark-coding-plan/doubao-seed-2.0-pro",
      "fallback_models": ["bailian-coding-plan/qwen3.5-plus", "minimax-cn-coding-plan/MiniMax-M2.5-highspeed"],
      "description": "Tasks that don't fit other categories, high effort required"
    },
    // writing: 文档写作 - GLM 5中文理解优秀
    "writing": {
      "model": "bailian-coding-plan/qwen3.5-plus",
      "fallback_models": ["ark-coding-plan/kimi-k2.5", "minimax-cn-coding-plan/MiniMax-M2.5-highspeed"],
      "temperature": 0.5,
      "description": "Documentation, prose, technical writing"
    },
    // 自定义: 代码审查专用
    "code-review": {
      "model": "ark-coding-plan/doubao-seed-2.0-code",
      "description": "Code review and quality analysis",
      "prompt_append": "Focus on code quality, security issues, and best practices."
    }
  },
  // ==========================================
  // 背景任务并发控制
  // ==========================================
  "background_task": {
    "defaultConcurrency": 8,
    "staleTimeoutMs": 180000,
    "providerConcurrency": { "bailian-coding-plan": 5, "ark-coding-plan": 5 },
    "modelConcurrency": { "bailian-coding-plan/qwen3.5-plus": 3 }
  },
  // ==========================================
  // 运行时回退配置
  // ==========================================
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  }
}
