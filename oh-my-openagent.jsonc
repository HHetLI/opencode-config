{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",

  // ==========================================
  // AGENTS 配置 - 针对可用模型优化
  // ==========================================
  "agents": {
    // Main orchestrator: handles delegation and drives tasks to completion
    "sisyphus": {
      "model": "deepseek/deepseek-v4-pro",
      "variant": "max",
      "thinking": {"type": "enabled"},
      "fallback_models": ["tencent-coding-plan/kimi-k2.5", "tencent-coding-plan/glm-5"],
      "prompt_append": "Always consult prometheus and atlas for planning. Never rush to implementation."
    },
    // Deep autonomous worker: end-to-end implementation
    "hephaestus": {
      "model": "deepseek/deepseek-v4-pro",
      "variant": "max",
      "prompt_append": "Follow established plans precisely. Ask for clarification when plans are ambiguous."
    },
    // Strategic planner: interview mode before execution
    "prometheus": {
      "model":  "deepseek/deepseek-v4-pro",
      "variant": "max",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-pro"],
      "prompt_append": "Always interview first, Validate scope before planning. Must reference to /test-driven-development skill"
    },
    // Plan consultant: reviews and improves plans
    "metis": {
      "model":  "deepseek/deepseek-v4-pro",
      "variant": "max",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-pro"],
      "prompt_append": "Critically evaluate plans. Identify gaps, risks, and improvements. Be thorough. must reference to /test-driven-development skill"
    },
    // Continuation and long-running task handler
    "atlas": {
      "model": "tencent-coding-plan/kimi-k2.5",
      "thinking": {"type": "enabled"}
    },
    // Architecture consultant: complex design and debugging
    "oracle": {
      "model":  "deepseek/deepseek-v4-pro",
      "variant": "max",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-pro"]
    },
    // Critic and reviewer
    "momus": {
      "model":  "deepseek/deepseek-v4-pro",
      "variant": "max",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-pro"],
      "prompt_append": "Challenge all assumptions in plans. Look for edge cases, failure modes, and overlooked requirements"
    },
    // Documentation and code search
    "librarian": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.7-highspeed",
      "fallback_models": [{"model": "deepseek/deepseek-v4-flash", "variant": "max"}]
    },
    // Fast codebase exploration
    "explore": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.7-highspeed",
      "fallback_models": [{"model": "deepseek/deepseek-v4-flash", "variant": "max"}]
    },
    // Visual tasks: UI/UX, images, diagrams
    "multimodal-looker": {
      "model": "ark-coding-plan/doubao-seed-2.0-pro",
      "fallback_models": ["tencent-coding-plan/kimi-k2.5"]
    },
    // Lightweight task executor for simple jobs
    "sisyphus-junior": {
      "model": "tencent-coding-plan/kimi-k2.5",
      "fallback_models": [{"model": "deepseek/deepseek-v4-flash", "variant": "max"}]
    }
  },
  // ==========================================
  // CATEGORIES 配置
  // ==========================================
  "categories": {
    // Visual work
    "visual-engineering": {
      "model": "tencent-coding-plan/glm-5",
      "fallback_models": ["tencent-coding-plan/kimi-k2.5"]
    },
    // Architecture decisions, Strategic reasoning
    "ultrabrain": {
      "model":  "deepseek/deepseek-v4-pro",
      "variant": "max",
      "fallback_models": ["tencent-coding-plan/glm-5"]
    },
    // Deep research and analysis
    "deep": {
      "model":  "deepseek/deepseek-v4-pro",
      "variant": "max",
      "fallback_models": ["tencent-coding-plan/glm-5", "ark-coding-plan/doubao-seed-2.0-pro"]
    },
    // Creative approaches to problems
    "artistry": {
      "model": "ark-coding-plan/doubao-seed-2.0-pro",
      "temperature": 0.9,
      "fallback_models": ["tencent-coding-plan/kimi-k2.5"]
    },
    // Trivial changes: fastest possible
    "quick": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.7-highspeed",
      "fallback_models": [{"model": "deepseek/deepseek-v4-flash", "variant": "max"}]
    },
    // Standard coding tasks: good quality, fast
    "unspecified-low": {
      "model":  "tencent-coding-plan/glm-5",
      "fallback_models": ["tencent-coding-plan/kimi-k2.5"]
    },
    // Complex refactors: best quality
    "unspecified-high": {
      "model":  "deepseek/deepseek-v4-pro",
      "variant": "max",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-pro"]
    },
    // Documentation from plans
    "writing": {
      "model": "tencent-coding-plan/kimi-k2.5",
      "fallback_models": [{"model": "deepseek/deepseek-v4-flash", "variant": "max"}]
    }
  },
  "model_fallback": true,
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  // ==========================================
  // 背景任务并发控制
  // ==========================================
  "background_task": {
    "defaultConcurrency": 8,
    "staleTimeoutMs": 180000,
    "providerConcurrency": { "tencent-coding-plan": 2 },
    "modelConcurrency": {
      "tencent-coding-plan/glm-5": 1
    }
  },
  // ==========================================
  // 运行时回退配置
  // ==========================================
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  }
}
