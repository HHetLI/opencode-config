{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",

  // ==========================================
  // AGENTS 配置 - 针对可用模型优化
  // ==========================================
  "agents": {
    // Sisyphus: 主协调器 - Kimi K2.5最佳(Claude-like + Agent Swarm)
    // 备选: GLM 5 (同为Claude-family, 表现类似)
    "sisyphus": {
      "model": "tencent-coding-plan/kimi-k2.5",
      "fallback_models": ["ark-coding-plan/glm-5", "ark-coding-plan/doubao-seed-2.0-pro", "bailian-coding-plan/qwen3.6-plus"],
      "reasoningEffort": "high",
      "prompt_append": "must reference to /test-driven-development skill"
    },
    // Hephaestus: 深度工作者 - 无GPT-5.3 Codex时最佳替代
    // 可以尝试 doubao-seed-2.0-code 和 glm 5
    "hephaestus": {
      "model": "ark-coding-plan/doubao-seed-2.0-code",
      "fallback_models": ["tencent-coding-plan/glm-5"],
      "reasoningEffort": "high"
    },
    // Prometheus: 战略规划 - 需要Claude-like的指令遵循
    "prometheus": {
      "model": "tencent-coding-plan/glm-5",
      "fallback_models": ["bailian-coding-plan/kimi-k2.5", "ark-coding-plan/doubao-seed-2.0-pro"],
      "reasoningEffort": "high",
      "prompt_append": "Always interview first. must reference to /test-driven-development skill"
    },
    // Metis: 计划顾问 - 同Prometheus
    "metis": {
      "model": "bailian-coding-plan/kimi-k2.5",
      "fallback_models": ["tencent-coding-plan/glm-5", "bailian-coding-plan/qwen3.6-plus"],
      "reasoningEffort": "high",
      "prompt_append": "must reference to /test-driven-development skill"
    },
    // Atlas: Todo执行者 - Kimi K2.5是最佳选择(文档明确推荐)
    "atlas": {
      "model": "tencent-coding-plan/kimi-k2.5",
      "fallback_models": ["bailian-coding-plan/kimi-k2.5", "ark-coding-plan/glm-5"],
      "reasoningEffort": "high"
    },
    // Oracle: 架构咨询 read-only
    "oracle": {
      "model": "ark-coding-plan/doubao-seed-2.0-pro",
      "fallback_models": ["tencent-coding-plan/glm-5", "bailian-coding-plan/qwen3.6-plus"],
      "reasoningEffort": "high"
    },
    // Momus: 计划审查 - 需要高IQ但read-only
    "momus": {
      "model": "ark-coding-plan/doubao-seed-2.0-pro",
      "fallback_models": ["tencent-coding-plan/glm-5", "bailian-coding-plan/kimi-k2.5"],
      "reasoningEffort": "high",
      "prompt_append": "must reference to /test-driven-development skill"
    },
    // Librarian: 文档搜索
    "librarian": {
      "model": "bailian-coding-plan/qwen3.6-plus",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-pro", "minimax-cn-coding-plan/MiniMax-M2.7-highspeed"]
    },
    // Explore: 快速grep
    "explore": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.7-highspeed",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-code","bailian-coding-plan/qwen3.6-plus"]
    },
    // Multimodal-Looker: 视觉分析
    "multimodal-looker": {
      "model": "tencent-coding-plan/kimi-k2.5",
      "fallback_models": ["bailian-coding-plan/qwen3.6-plus", "ark-coding-plan/doubao-seed-2.0-pro"]
    }
  },
  // ==========================================
  // CATEGORIES 配置
  // ==========================================
  "categories": {
    // visual-engineering: UI/前端
    "visual-engineering": {
      "model": "tencent-coding-plan/kimi-k2.5" ,
      "fallback_models": ["bailian-coding-plan/qwen3.6-plus", "ark-coding-plan/doubao-seed-2.0-code"]
    },
    // ultrabrain: 极限推理
    "ultrabrain": {
      "model": "tencent-coding-plan/glm-5",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-pro", "bailian-coding-plan/qwen3.6-plus"],
      "reasoningEffort": "high"
    },
    // deep: 深度编码
    "deep": {
      "model": "ark-coding-plan/doubao-seed-2.0-code",
      "fallback_models": ["tencent-coding-plan/glm-5"],
      "reasoningEffort": "medium"
    },
    // artistry: 创意任务
    "artistry": {
      "model": "bailian-coding-plan/qwen3.6-plus",
      "temperature": 0.9,
      "fallback_models": ["tencent-coding-plan/kimi-k2.5", "minimax-cn-coding-plan/MiniMax-M2.7-highspeed"]
    },
    // quick: 快速任务
    "quick": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.7-highspeed",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-code"]
    },
    // unspecified-low: 一般低强度
    "unspecified-low": {
      "model":  "bailian-coding-plan/qwen3.6-plus",
      "fallback_models": ["ark-coding-plan/doubao-seed-2.0-pro"]
    },
    // unspecified-high: 一般高强度
    "unspecified-high": {
      "model": "ark-coding-plan/doubao-seed-2.0-pro",
      "fallback_models": ["tencent-coding-plan/glm-5"]
    },
    // writing: 文档写作
    "writing": {
      "model": "bailian-coding-plan/qwen3.6-plus",
      "fallback_models": ["tencent-coding-plan/kimi-k2.5", "minimax-cn-coding-plan/MiniMax-M2.7-highspeed"]
    }
  },
  "model_fallback": true,
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  // ==========================================
  // 背景任务并发控制
  // ==========================================
  "background_task": {
    "defaultConcurrency": 8,
    "staleTimeoutMs": 180000,
    "providerConcurrency": { "bailian-coding-plan": 2, "ark-coding-plan": 2, "tencent-coding-plan": 2 },
    "modelConcurrency": {
      "bailian-coding-plan/kimi-k2.5": 1,
      "bailian-coding-plan/glm-5": 1,
      "ark-coding-plan/kimi-k2.5": 1,
      "ark-coding-plan/glm-5": 1
    }
  },
  // ==========================================
  // 运行时回退配置
  // ==========================================
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  }
}
